{
  "name": "tegro-money-mcp",
  "version": "0.1.0",
  "description": "MCP server for Tegro.Money — connect Claude, Cursor and other AI tools to the Tegro.Money payment API (balances, shops, orders, payouts, rates). Read-only, secure, your API key never leaves your machine.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "tegro",
    "tegro-money",
    "payments",
    "payment-api",
    "payment-gateway",
    "sbp",
    "crypto-payments",
    "acquiring",
    "claude",
    "cursor",
    "ai-tools",
    "llm"
  ],
  "homepage": "https://github.com/TegroTON/mcp-money#readme",
  "bugs": {
    "url": "https://github.com/TegroTON/mcp-money/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TegroTON/mcp-money.git"
  },
  "license": "MIT",
  "author": "Tegro.Money",
  "type": "module",
  "bin": {
    "tegro-money-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.8.3"
  }
}
