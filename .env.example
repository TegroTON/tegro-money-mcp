# Your Tegro.Money REST API key (dashboard → project → Settings → Keys → API KEY).
# Used ONLY to sign requests locally; never sent over the network.
TEGRO_API_KEY=

# Optional: default Shop ID (public key) for shop-scoped tools.
TEGRO_SHOP_ID=

# Optional: API base URL (default https://tegro.money)
# TEGRO_API_BASE=https://tegro.money
